rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/videos/{videoFile} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    match /sharedVideos/{videoFile} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
